{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Launch (console)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build", // Сначала запускает задачу сборки из tasks.json
            "program": "${workspaceFolder}/BelTCrypto.Core/bin/Debug/net10.0/BelTCrypto.Core.dll", // Путь к исполняемому файлу
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "internalConsole"
        },
        {
            "name": ".NET Core Attach",
            "type": "coreclr",
            "request": "attach"
        },
        {
    "name": ".NET Debug Unit Tests",
    "type": "coreclr",
    "request": "launch",
    "preLaunchTask": "build",
    "program": "dotnet",
    "args": [
        "test",
        "${workspaceFolder}/BelTCrypto.Tests/BelTCrypto.Tests.csproj",
        "--filter", "FullyQualifiedName=BelTCrypto.Tests.BlockTests.Encrypt_MatchStandardVector_A1"
    ],
    "cwd": "${workspaceFolder}",
    "console": "internalConsole"
}
    ]
}