{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}/BelTCrypto.Core.csproj", // Замени на имя своего .csproj
                "/property:GenerateFullPaths=true",
                "/consoleloggerparameters:NoSummary"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "run",
                "--project",
                "${workspaceFolder}/BelTCrypto.Net/BelTCrypto.Core.csproj"
            ],
            "problemMatcher": "$msCompile"
        }
    ],
    "configurations": [
    
    ]
}